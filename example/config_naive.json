{
  "Log": {
    "Level": "info",
    "Output": ""
  },
  "Cores": [
    {
      "Type": "sing",
      "Log": {
        "Level": "error",
        "Timestamp": true
      },
      "NTP": {
        "Enable": true,
        "Server": "time.apple.com",
        "ServerPort": 0
      }
    }
  ],
  "Nodes": [
    {
      "Name": "naive-demo",
      "Core": "sing",
      "ApiHost": "https://panel.example.com",
      "ApiKey": "your-api-key",
      "NodeID": 1,
      "NodeType": "naive",
      "Timeout": 30,
      "ListenIP": "0.0.0.0",
      "SendIP": "0.0.0.0",
      "EnableTFO": true,
      "EnableDNS": true,
      "DomainStrategy": "ipv4_only",
      "CertConfig": {
        "CertMode": "file",
        "RejectUnknownSni": false,
        "CertDomain": "naive.example.com",
        "CertFile": "/etc/V2bX/fullchain.cer",
        "KeyFile": "/etc/V2bX/cert.key",
        "Provider": "cloudflare",
        "Email": "admin@example.com",
        "DNSEnv": {
          "EnvName": "env1"
        }
      }
    }
  ]
}
